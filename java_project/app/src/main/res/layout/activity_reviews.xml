<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEEAEA"
    android:orientation="vertical"
    android:paddingStart="18dp"
    android:paddingTop="42dp"
    android:paddingEnd="18dp">

    <!-- TOP BAR START -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <!-- Back Button -->
        <LinearLayout
            android:id="@+id/reviewsBackButton"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/review_top_circle_button"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center">

            <!-- Buraya geri ikonu gelecek -->
            <ImageView
                android:layout_width="17dp"
                android:layout_height="17dp"
                android:src="@drawable/arrow_small_left" />

        </LinearLayout>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Ratings and Reviews"
            android:textColor="#000000"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- Share Button -->
        <LinearLayout
            android:id="@+id/reviewsShareButton"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/review_top_circle_button"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center">

            <!-- Buraya paylaş ikonu gelecek -->
            <ImageView
                android:layout_width="17dp"
                android:layout_height="17dp"
                android:src="@drawable/share" />

        </LinearLayout>

    </LinearLayout>
    <!-- TOP BAR END -->


    <!-- RATING SUMMARY CARD START -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="110dp"
        android:layout_marginTop="18dp"
        android:background="@drawable/review_summary_card_background"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="★★★★★"
            android:textColor="#F6C700"
            android:textSize="25sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="5.0 ( 1,092 Reviews)"
            android:textColor="#000000"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Outstanding: Rated 5.0 with 1,092 Reviews"
            android:textColor="#AAAAAA"
            android:textSize="12sp" />

    </LinearLayout>
    <!-- RATING SUMMARY CARD END -->


    <!-- REVIEWS HEADER START -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginTop="14dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="1,092 Reviews"
            android:textColor="#000000"
            android:textSize="20sp"
            android:textStyle="bold" />

        <!-- Latest dropdown görünümü, çalışmasına gerek yok -->
        <LinearLayout
            android:id="@+id/latestFilterView"
            android:layout_width="74dp"
            android:layout_height="28dp"
            android:background="@drawable/latest_filter_background"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Latest"
                android:textColor="#000000"
                android:textSize="12sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:text="⌄"
                android:textColor="#000000"
                android:textSize="12sp" />

        </LinearLayout>

    </LinearLayout>
    <!-- REVIEWS HEADER END -->


    <!-- REVIEW LIST START -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="12dp"
            android:paddingBottom="24dp">

            <!-- REVIEW CARD 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/review_card_background"
                android:orientation="vertical"
                android:padding="18dp">

                <!-- User row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <!-- Buraya kullanıcı fotoğrafı gelecek -->
                    <ImageView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/person1" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Jamal Abdul"
                            android:textColor="#000000"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="New user on Hotelia"
                            android:textColor="#777777"
                            android:textSize="12sp" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="★"
                        android:textColor="#F6C700"
                        android:textSize="25sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="5.0"
                        android:textColor="#000000"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="This app is a game-changer! Easy to use, tons of options, and amazing deals. My go-to for all travel plans. Highly recommended!"
                    android:textColor="#000000"
                    android:textSize="13sp"
                    android:lineSpacingExtra="2dp" />

            </LinearLayout>


            <!-- REVIEW CARD 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="26dp"
                android:background="@drawable/review_card_background"
                android:orientation="vertical"
                android:padding="18dp">

                <!-- User row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <!-- Buraya kullanıcı fotoğrafı gelecek -->
                    <ImageView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/person2" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Kamila Kabelo"
                            android:textColor="#000000"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="8 Months Using Hotelia"
                            android:textColor="#777777"
                            android:textSize="12sp" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="★"
                        android:textColor="#F6C700"
                        android:textSize="25sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="4.9"
                        android:textColor="#000000"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="Impressive app! It simplifies hotel booking with its user-friendly interface and great prices. Never disappoints. A must-have for frequent travelers."
                    android:textColor="#000000"
                    android:textSize="13sp"
                    android:lineSpacingExtra="2dp" />

            </LinearLayout>


            <!-- REVIEW CARD 3 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="26dp"
                android:background="@drawable/review_card_background"
                android:orientation="vertical"
                android:padding="18dp">

                <!-- User row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <!-- Buraya kullanıcı fotoğrafı gelecek -->
                    <ImageView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/person3" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Shena Kerren"
                            android:textColor="#000000"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="3 Months Using Hotelia"
                            android:textColor="#777777"
                            android:textSize="12sp" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="★"
                        android:textColor="#F6C700"
                        android:textSize="25sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="4.8"
                        android:textColor="#000000"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="Love this app! It’s my travel companion for finding the best hotels. Smooth transactions, accurate listings, and excellent customer service. Highly satisfied!"
                    android:textColor="#000000"
                    android:textSize="13sp"
                    android:lineSpacingExtra="2dp" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>
    <!-- REVIEW LIST END -->

</LinearLayout>