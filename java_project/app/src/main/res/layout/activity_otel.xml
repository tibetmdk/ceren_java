<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:orientation="vertical">

    <!-- ÜST RESİM ALANI START -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.85">

        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/hotelImagePager"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!-- Sol üst geri butonu -->
        <LinearLayout
            android:id="@+id/detailBackButton"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_gravity="top|start"
            android:layout_marginStart="18dp"
            android:layout_marginTop="42dp"
            android:background="@drawable/detail_circle_dark_button"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/arrow_small_left" />

        </LinearLayout>

        <!-- Sağ üst paylaş butonu -->
        <LinearLayout
            android:id="@+id/shareButton"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_gravity="top|end"
            android:layout_marginTop="42dp"
            android:layout_marginEnd="18dp"
            android:background="@drawable/detail_circle_dark_button"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/share" />

        </LinearLayout>

    </FrameLayout>
    <!-- ÜST RESİM ALANI END -->


    <!-- ALT ALAN START -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1.15"
        android:orientation="vertical">

        <!-- Scroll edilen detay alanı -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="18dp"
                android:paddingTop="18dp"
                android:paddingEnd="18dp"
                android:paddingBottom="16dp">

                <!-- Otel adı + favori -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Sheraton Bali Hotel"
                        android:textColor="#000000"
                        android:textSize="25sp"
                        android:textStyle="bold" />

                    <!-- Buraya kalp ikonu gelecek -->
                    <ImageView
                        android:id="@+id/favoriteButton"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/save" />

                </LinearLayout>

                <!-- Konum + rating -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <!-- Buraya location ikonu gelecek -->
                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/location" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="5dp"
                        android:text="Bali, Indonesia"
                        android:textColor="#555555"
                        android:textSize="14sp" />

                    <Space
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="★"
                        android:textColor="#FFD500"
                        android:textSize="21sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="5dp"
                        android:text="4.9/5 (999 Reviews)"
                        android:textColor="#000000"
                        android:textSize="14sp" />

                </LinearLayout>

                <!-- Popular Facilities başlığı -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="26dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Popular Facilities"
                        android:textColor="#000000"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/seeAllFacilitiesText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="See all"
                        android:textColor="#22A45D"
                        android:textSize="14sp" />

                </LinearLayout>

                <!-- Facilities yatay scroll -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:scrollbars="none">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <!-- Facility 1 -->
                        <LinearLayout
                            android:layout_width="110dp"
                            android:layout_height="60dp"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/facility_box_background"
                            android:gravity="center_vertical"
                            android:orientation="vertical"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp">

                            <!-- Buraya bedroom ikonu gelecek -->
                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:src="@drawable/bed" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="3dp"
                                android:text="4 Bedrooms"
                                android:textColor="#000000"
                                android:textSize="11sp" />

                        </LinearLayout>

                        <!-- Facility 2 -->
                        <LinearLayout
                            android:layout_width="110dp"
                            android:layout_height="60dp"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/facility_box_background"
                            android:gravity="center_vertical"
                            android:orientation="vertical"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp">

                            <!-- Buraya bathroom ikonu gelecek -->
                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:src="@drawable/bath" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="3dp"
                                android:text="2 Bathrooms"
                                android:textColor="#000000"
                                android:textSize="11sp" />

                        </LinearLayout>

                        <!-- Facility 3 -->
                        <LinearLayout
                            android:layout_width="125dp"
                            android:layout_height="60dp"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/facility_box_background"
                            android:gravity="center_vertical"
                            android:orientation="vertical"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp">

                            <!-- Buraya pool ikonu gelecek -->
                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:src="@drawable/swimming_pool" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="3dp"
                                android:text="Swimming Pool"
                                android:textColor="#000000"
                                android:textSize="11sp" />

                        </LinearLayout>

                        <!-- Facility 4 -->
                        <LinearLayout
                            android:layout_width="110dp"
                            android:layout_height="60dp"
                            android:background="@drawable/facility_box_background"
                            android:gravity="center_vertical"
                            android:orientation="vertical"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp">

                            <!-- Buraya restaurant ikonu gelecek -->
                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:src="@drawable/restaurant" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="3dp"
                                android:text="Restaurant"
                                android:textColor="#000000"
                                android:textSize="11sp" />

                        </LinearLayout>

                    </LinearLayout>

                </HorizontalScrollView>

                <!-- Location başlığı -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="22dp"
                    android:text="Location"
                    android:textColor="#000000"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <!-- Harita resmi -->
                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/locationMapImage"
                    android:layout_width="match_parent"
                    android:layout_height="88dp"
                    android:layout_marginTop="10dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/map_image"
                    app:shapeAppearanceOverlay="@style/MapImageRounded" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Jl. Kesana No.88, Gerobogan, Kuta Utara, Badung, Bali"
                    android:textColor="#777777"
                    android:textSize="12sp" />

                <!-- Nearest Destinations -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="22dp"
                    android:text="Nearest Destinations"
                    android:textColor="#000000"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <!-- Destination 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <!-- Buraya destination ikonu gelecek -->
                    <LinearLayout
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/destination_circle_background"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/shopping_bag" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:text="Pasar Legi Taman Griya"
                        android:textColor="#000000"
                        android:textSize="13sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="28m"
                        android:textColor="#000000"
                        android:textSize="13sp" />

                </LinearLayout>

                <!-- Destination 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <!-- Buraya destination ikonu gelecek -->
                    <LinearLayout
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/destination_circle_background"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/roller_coaster" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:text="Paratualang Adventure"
                        android:textColor="#000000"
                        android:textSize="13sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="63m"
                        android:textColor="#000000"
                        android:textSize="13sp" />

                </LinearLayout>

            </LinearLayout>

        </ScrollView>

        <!-- Alt fiyat + booking bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="82dp"
            android:background="#FFFFFF"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="28dp"
            android:paddingEnd="28dp">

            <!-- Fiyat kısmı -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="$10,210"
                        android:textColor="#22A45D"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" / night"
                        android:textColor="#000000"
                        android:textSize="16sp" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="4.698 point"
                    android:textColor="#777777"
                    android:textSize="12sp" />

            </LinearLayout>

            <!-- Booking Now butonu -->
            <LinearLayout
                android:id="@+id/bookingNowButton"
                android:layout_width="150dp"
                android:layout_height="48dp"
                android:background="@drawable/booking_now_button_background"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Booking Now"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
    <!-- ALT ALAN END -->

</LinearLayout>