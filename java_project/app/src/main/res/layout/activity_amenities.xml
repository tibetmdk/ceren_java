<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:orientation="vertical"
    android:paddingStart="22dp"
    android:paddingTop="42dp"
    android:paddingEnd="22dp">

    <!-- TOP BAR START -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <!-- Back Button -->
        <LinearLayout
            android:id="@+id/amenitiesBackButton"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/amenity_circle_button_background"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center">

            <!-- Buraya geri ikonu gelecek -->
            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/arrow_small_left" />

        </LinearLayout>

        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <!-- Favorite Button -->
        <LinearLayout
            android:id="@+id/amenitiesFavoriteButton"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/amenity_circle_button_background"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center">

            <!-- Buraya kalp ikonu gelecek -->
            <ImageView
                android:layout_width="17dp"
                android:layout_height="17dp"
                android:src="@drawable/save" />

        </LinearLayout>

        <!-- Share Button -->
        <LinearLayout
            android:id="@+id/amenitiesShareButton"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="10dp"
            android:background="@drawable/amenity_circle_button_background"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center">

            <!-- Buraya paylaş ikonu gelecek -->
            <ImageView
                android:layout_width="17dp"
                android:layout_height="17dp"
                android:src="@drawable/share" />

        </LinearLayout>

    </LinearLayout>
    <!-- TOP BAR END -->


    <!-- TITLE -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Amenities"
        android:textColor="#000000"
        android:textSize="18sp"
        android:textStyle="bold" />


    <!-- AMENITIES LIST START -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="vertical">

        <!-- Bathroom -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/amenity_icon_circle_background"
                android:gravity="center">

                <!-- Buraya bathroom ikonu gelecek -->
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/bath" />

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="Bathroom"
                android:textColor="#000000"
                android:textSize="17sp" />

        </LinearLayout>

        <!-- Hygiene Products -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/amenity_icon_circle_background"
                android:gravity="center">

                <!-- Buraya hygiene ikonu gelecek -->
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/shower_gel" />

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="Hygiene Products"
                android:textColor="#000000"
                android:textSize="17sp" />

        </LinearLayout>

        <!-- Bedroom -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/amenity_icon_circle_background"
                android:gravity="center">

                <!-- Buraya bedroom ikonu gelecek -->
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/bed" />

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="Bedroom"
                android:textColor="#000000"
                android:textSize="17sp" />

        </LinearLayout>

        <!-- Bedcover -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/amenity_icon_circle_background"
                android:gravity="center">

                <!-- Buraya bedcover ikonu gelecek -->
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/blanket" />

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="Bedcover"
                android:textColor="#000000"
                android:textSize="17sp" />

        </LinearLayout>

        <!-- Hanger -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/amenity_icon_circle_background"
                android:gravity="center">

                <!-- Buraya hanger ikonu gelecek -->
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/hanger" />

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="Hanger"
                android:textColor="#000000"
                android:textSize="17sp" />

        </LinearLayout>

        <!-- Security -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/amenity_icon_circle_background"
                android:gravity="center">

                <!-- Buraya security ikonu gelecek -->
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/security" />

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="Security"
                android:textColor="#000000"
                android:textSize="17sp" />

        </LinearLayout>

        <!-- Minibar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/amenity_icon_circle_background"
                android:gravity="center">

                <!-- Buraya minibar ikonu gelecek -->
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/minibar" />

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="Minibar"
                android:textColor="#000000"
                android:textSize="17sp" />

        </LinearLayout>

        <!-- Free Wifi -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/amenity_icon_circle_background"
                android:gravity="center">

                <!-- Buraya wifi ikonu gelecek -->
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/wifi_2" />

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="Free Wifi"
                android:textColor="#000000"
                android:textSize="17sp" />

        </LinearLayout>

        <!-- Laundry -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/amenity_icon_circle_background"
                android:gravity="center">

                <!-- Buraya laundry ikonu gelecek -->
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/laundry" />

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="Laundry"
                android:textColor="#000000"
                android:textSize="17sp" />

        </LinearLayout>

        <!-- Events -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/amenity_icon_circle_background"
                android:gravity="center">

                <!-- Buraya events ikonu gelecek -->
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/events" />

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="Events"
                android:textColor="#000000"
                android:textSize="17sp" />

        </LinearLayout>

        <!-- Television -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/amenity_icon_circle_background"
                android:gravity="center">

                <!-- Buraya television ikonu gelecek -->
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/tv" />

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="Television"
                android:textColor="#000000"
                android:textSize="17sp" />

        </LinearLayout>

    </LinearLayout>
    <!-- AMENITIES LIST END -->

</LinearLayout>