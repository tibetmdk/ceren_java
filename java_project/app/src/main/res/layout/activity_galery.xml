<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingTop="42dp"
    android:paddingEnd="16dp">

    <!-- TOP BAR START -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <!-- Back Button -->
        <LinearLayout
            android:id="@+id/galleryBackButton"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/gallery_circle_button_background"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center">

            <!-- Buraya geri ikonu gelecek -->
            <ImageView
                android:layout_width="17dp"
                android:layout_height="17dp"
                android:src="@drawable/arrow_small_left" />

        </LinearLayout>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Gallery"
            android:textColor="#000000"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- Share Button -->
        <LinearLayout
            android:id="@+id/galleryShareButton"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/gallery_circle_button_background"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center">

            <!-- Buraya paylaş ikonu gelecek -->
            <ImageView
                android:layout_width="17dp"
                android:layout_height="17dp"
                android:src="@drawable/share" />

        </LinearLayout>

    </LinearLayout>
    <!-- TOP BAR END -->


    <!-- GALLERY SCROLL START -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="14dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- IMAGE 1: Büyük üst fotoğraf -->
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/galleryImage1"
                android:layout_width="match_parent"
                android:layout_height="150dp"
                android:scaleType="centerCrop"
                android:src="@drawable/gallery_image1"
                app:shapeAppearanceOverlay="@style/GalleryImageRounded" />

            <!-- ROW 1: Image 2 - Image 3 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/galleryImage2"
                    android:layout_width="0dp"
                    android:layout_height="145dp"
                    android:layout_weight="1"
                    android:scaleType="centerCrop"
                    android:src="@drawable/gallery_image_2"
                    app:shapeAppearanceOverlay="@style/GalleryImageRounded" />

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/galleryImage3"
                    android:layout_width="0dp"
                    android:layout_height="145dp"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:scaleType="centerCrop"
                    android:src="@drawable/gallery_image_3"
                    app:shapeAppearanceOverlay="@style/GalleryImageRounded" />

            </LinearLayout>

            <!-- ROW 2: Image 4 - Image 5 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/galleryImage4"
                    android:layout_width="0dp"
                    android:layout_height="145dp"
                    android:layout_weight="1"
                    android:scaleType="centerCrop"
                    android:src="@drawable/gallery_image_4"
                    app:shapeAppearanceOverlay="@style/GalleryImageRounded" />

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/galleryImage5"
                    android:layout_width="0dp"
                    android:layout_height="145dp"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:scaleType="centerCrop"
                    android:src="@drawable/gallery_image_5"
                    app:shapeAppearanceOverlay="@style/GalleryImageRounded" />

            </LinearLayout>

            <!-- ROW 3: Image 6 - Image 7 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/galleryImage6"
                    android:layout_width="0dp"
                    android:layout_height="145dp"
                    android:layout_weight="1"
                    android:scaleType="centerCrop"
                    android:src="@drawable/gallery_image_6"
                    app:shapeAppearanceOverlay="@style/GalleryImageRounded" />

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/galleryImage7"
                    android:layout_width="0dp"
                    android:layout_height="145dp"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:scaleType="centerCrop"
                    android:src="@drawable/gallery_image_7"
                    app:shapeAppearanceOverlay="@style/GalleryImageRounded" />

            </LinearLayout>

            <!-- ROW 4: Image 8 - Image 9 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/galleryImage8"
                    android:layout_width="0dp"
                    android:layout_height="145dp"
                    android:layout_weight="1"
                    android:scaleType="centerCrop"
                    android:src="@drawable/gallery_image_8"
                    app:shapeAppearanceOverlay="@style/GalleryImageRounded" />

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/galleryImage9"
                    android:layout_width="0dp"
                    android:layout_height="145dp"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:scaleType="centerCrop"
                    android:src="@drawable/gallery_image_9"
                    app:shapeAppearanceOverlay="@style/GalleryImageRounded" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>
    <!-- GALLERY SCROLL END -->

</LinearLayout>